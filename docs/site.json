{
  "baseUrl": "/betadocs",
  "timeZone": "Asia/Singapore",
  "titlePrefix": "",
  "titleSuffix": "",
  "ignore": [
    "_markbind/layouts/*",
    "_markbind/logs/*",
    "_site/*",
    "site.json",
    "*.md",
    "*.njk",
    ".git/*",
    ".gitignore",
    "node_modules/*",
    "CNAME"
  ],
  "pagesExclude": ["node_modules/*"],
  "pages": [
    {
      "src": "index.md"
    },
    {
      "glob": ["**/index.md", "**/*.md"]
    }
  ],
  "style": {
    "codeTheme": "light"
  },
  "plugins": [
    "custardui",
    "filterTags",
    "codeBlockCopyButtons",
    "codeBlockWrapButtons",
    "mermaid"
  ],
  "pluginsContext": {
    "filterTags": {
      "tags": ["beta-release"]
    }
  },
  "deploy": {
    "message": "Site Update.",
    "repo": "https://github.com/custardUI/betadocs.git",
    "branch": "master"
  }
}
